---
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';
import { url } from '@utils/url';

export async function getStaticPaths() {
  const [allNews, allInsights] = await Promise.all([
    getCollection('news', ({ data }) => !data.draft),
    getCollection('insights', ({ data }) => !data.draft),
  ]);

  const tagSet = new Set<string>();
  allNews.forEach((e) => e.data.tags.forEach((t) => tagSet.add(t)));
  allInsights.forEach((e) => e.data.tags.forEach((t) => tagSet.add(t)));

  return Array.from(tagSet).map((tag) => {
    const newsItems = allNews
      .filter((e) => e.data.tags.includes(tag))
      .map((e) => ({ ...e, _type: 'news' as const }));
    const insightItems = allInsights
      .filter((e) => e.data.tags.includes(tag))
      .map((e) => ({ ...e, _type: 'insights' as const }));

    const combined = [...newsItems, ...insightItems].sort(
      (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
    );

    return {
      params: { tag },
      props: { tag, items: combined },
    };
  });
}

const { tag, items } = Astro.props;
---

<Page
  title={`標籤：${tag}`}
  description={`與「${tag}」相關的新聞與知識文章。`}
>
  <div class="container page-content">

    <header class="page-header">
      <div class="tag-badge" aria-label="當前標籤">
        <span class="tag-hash" aria-hidden="true">#</span>
        {tag}
      </div>
      <h1 class="page-title">標籤：{tag}</h1>
      <p class="page-subtitle">共 {items.length} 篇相關文章</p>
    </header>

    {items.length === 0 ? (
      <p class="empty-state">暫無相關文章。</p>
    ) : (
      <div class="results-list">
        {items.map((item) => (
          <a
            href={url(`/${item._type}/${item.id}/`)}
            class="result-item"
          >
            <div class="result-item__meta">
              <span class={`result-item__type result-item__type--${item._type}`}>
                {item._type === 'news' ? '最新動態' : '知識庫'}
              </span>
              <time class="result-item__date" datetime={item.data.publishDate.toISOString()}>
                {item.data.publishDate.toLocaleDateString('zh-Hant-TW', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </div>
            <h2 class="result-item__title">{item.data.title}</h2>
            <p class="result-item__summary">{item.data.summary}</p>
            <div class="result-item__tags">
              {item.data.tags.map((t) => (
                <span class={`result-tag ${t === tag ? 'result-tag--active' : ''}`}>{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    )}

    <div class="back-nav">
      <a href={url('/news/')} class="back-link">← 最新動態</a>
      <a href={url('/insights/')} class="back-link">← 知識庫</a>
    </div>

  </div>
</Page>

<style>
  .page-content {
    padding-block: var(--space-3xl);
  }

  .page-header {
    margin-bottom: var(--space-3xl);
  }

  .tag-badge {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: var(--space-sm) var(--space-lg);
    background-color: var(--color-primary);
    color: var(--color-paper);
    font-size: var(--text-lg);
    font-weight: 700;
    border-radius: 9999px;
    margin-bottom: var(--space-lg);
  }

  .tag-hash {
    opacity: 0.7;
  }

  .page-title {
    font-size: var(--text-4xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-sm);
  }

  .page-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
  }

  .empty-state {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    text-align: center;
    padding: var(--space-3xl);
  }

  .results-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-3xl);
  }

  .result-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-xl);
    background-color: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .result-item:hover {
    border-color: var(--color-primary-light);
    box-shadow: var(--shadow-sm);
  }

  .result-item__meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .result-item__type {
    padding: 2px var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 700;
    border-radius: var(--radius-sm);
  }

  .result-item__type--news {
    background-color: var(--color-type-news-bg);
    color: var(--color-type-news-text);
  }

  .result-item__type--insights {
    background-color: var(--color-type-insights-bg);
    color: var(--color-type-insights-text);
  }

  .result-item__date {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .result-item__title {
    font-size: var(--text-xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
  }

  .result-item__summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .result-item__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .result-tag {
    padding: 2px var(--space-sm);
    background-color: var(--color-surface);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .result-tag--active {
    background-color: var(--color-primary-pale);
    color: var(--color-primary);
    border-color: var(--color-primary-light);
    font-weight: 600;
  }

  .back-nav {
    display: flex;
    gap: var(--space-lg);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>

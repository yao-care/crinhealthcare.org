---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import EmsBoard from '../components/charts/EmsBoard.svelte';

export async function getStaticPaths() {
  const hospitals = await getCollection('hospitals');
  return hospitals.map((h) => ({
    params: { hospital: h.id },
    props: { hospital: h.data },
  }));
}

const { hospital } = Astro.props;
---

<Base
  title={`${hospital.name} · 平戰轉EMS`}
  description={`${hospital.name} 平戰轉 EMS 能源資源看板：供 → 儲 → 用 → 效，平時／戰時切換。`}
>
  <EmsBoard hospital={hospital} client:visible />
</Base>

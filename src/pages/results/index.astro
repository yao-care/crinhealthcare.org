---
import Page from '@layouts/Page.astro';
import CountUp from '@components/charts/CountUp.svelte';
import MetricsDashboard from '@components/charts/MetricsDashboard.svelte';
import { getCollection } from 'astro:content';
import { aggregateMetrics } from '@utils/metrics';

const cases = await getCollection('case-studies', ({ data }) => !data.draft);
const metrics = await aggregateMetrics();

const dashboardData = cases.map((c) => ({
  name: c.data.hospital.name,
  location: c.data.hospital.location,
  system: c.data.hospital.system,
  slug: c.id,
  energySaving: c.data.metrics.energySavingPercent ?? 0,
  subsidy: c.data.metrics.subsidyAmount ?? 0,
  services: c.data.services,
}));
---

<Page
  title="合作成果"
  description="國際醫療減碳協會的合作成果數據，包含合作醫院數量、補助申請金額、節能成效等關鍵指標。"
>
  <div class="container page-content">

    <header class="page-header">
      <h1 class="page-title">合作成果</h1>
      <p class="page-lead">
        用數字說話：協會自成立以來協助醫療院所達成的具體成效。
      </p>
    </header>

    <section class="metrics-section">
      <CountUp client:visible metrics={metrics} />
    </section>

    {cases.length > 0 && (
      <section class="dashboard-section">
        <h2 class="section-heading">各院所詳細數據</h2>
        <MetricsDashboard client:visible hospitals={dashboardData} />
      </section>
    )}

    <section class="case-links">
      <h2 class="section-heading">深入了解合作案例</h2>
      <div class="case-grid">
        {cases.map((c) => (
          <a href={`/case-studies/${c.id}/`} class="case-link">
            <div class="case-link__badge">{c.data.hospital.system === 'military' ? '國軍' : c.data.hospital.system === 'veterans' ? '榮民' : '其他'}</div>
            <div class="case-link__name">{c.data.hospital.name}</div>
            <div class="case-link__location">{c.data.hospital.location}</div>
            <div class="case-link__arrow" aria-hidden="true">→</div>
          </a>
        ))}
      </div>
    </section>

  </div>
</Page>

<style>
  .page-content {
    padding-block: var(--space-3xl);
  }

  .page-header {
    max-width: 72ch;
    margin-bottom: var(--space-3xl);
  }

  .page-title {
    font-size: var(--text-4xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-lg);
  }

  .page-lead {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: var(--leading-loose);
  }

  .metrics-section {
    background-color: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-bottom: var(--space-3xl);
  }

  .dashboard-section {
    margin-bottom: var(--space-3xl);
  }

  .section-heading {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .case-links {
    margin-bottom: var(--space-3xl);
  }

  .case-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .case-link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    column-gap: var(--space-sm);
    padding: var(--space-lg);
    background-color: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .case-link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-sm);
  }

  .case-link__badge {
    grid-row: 1 / 3;
    align-self: center;
    padding: var(--space-xs) var(--space-sm);
    background-color: var(--color-primary-pale);
    color: var(--color-primary);
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-sm);
  }

  .case-link__name {
    font-weight: 600;
    color: var(--color-text);
    font-size: var(--text-sm);
  }

  .case-link__location {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .case-link__arrow {
    grid-row: 1 / 3;
    align-self: center;
    color: var(--color-primary);
    font-size: var(--text-lg);
  }

  @media (max-width: 768px) {
    .case-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

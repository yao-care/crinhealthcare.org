---
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';

const allFaq = await getCollection('faq');
const sorted = allFaq.sort((a, b) => a.data.order - b.data.order);

const categories = [
  { id: 'general', label: '一般問題' },
  { id: 'membership', label: '會員申請' },
  { id: 'carbon-audit', label: '碳盤查服務' },
  { id: 'ems', label: '能源管理系統' },
  { id: 'esg', label: 'ESG 報告' },
  { id: 'subsidy', label: '補助申請' },
] as const;

type FaqCategoryId = 'general' | 'membership' | 'carbon-audit' | 'ems' | 'esg' | 'subsidy';

const byCategory = categories.reduce(
  (acc, cat) => {
    acc[cat.id] = sorted.filter((f) => f.data.category === cat.id);
    return acc;
  },
  {} as Record<FaqCategoryId, typeof sorted>
);
---

<Page
  title="常見問題"
  description="國際醫療減碳協會常見問題解答，涵蓋碳盤查、能源管理、ESG報告、補助申請等服務說明。"
>
  <div class="container page-content">

    <header class="page-header">
      <h1 class="page-title">常見問題</h1>
      <p class="page-lead">
        找不到答案嗎？歡迎<a href="/contact/">聯繫我們</a>，協會同仁將為您解答。
      </p>
    </header>

    {categories.map((cat) => (
      byCategory[cat.id].length > 0 && (
        <section class="faq-section">
          <h2 class="faq-section__heading">{cat.label}</h2>
          <div class="faq-list">
            {byCategory[cat.id].map((item) => (
              <details class="faq-item">
                <summary class="faq-item__question">
                  <span class="faq-item__q-icon" aria-hidden="true">Q</span>
                  <span class="faq-item__q-text">{item.data.question}</span>
                  <span class="faq-item__chevron" aria-hidden="true">▾</span>
                </summary>
                <div class="faq-item__answer">
                  <span class="faq-item__a-icon" aria-hidden="true">A</span>
                  <p>{item.data.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </section>
      )
    ))}

    {allFaq.length === 0 && (
      <p class="empty-state">FAQ 資料準備中，敬請期待。</p>
    )}

    <section class="contact-cta">
      <h2 class="contact-cta__title">還有其他問題？</h2>
      <p class="contact-cta__desc">我們的專業團隊隨時準備為您解答。</p>
      <a href="/contact/" class="btn btn--primary">立即聯繫協會</a>
    </section>

  </div>
</Page>

<style>
  .page-content {
    padding-block: var(--space-3xl);
  }

  .page-header {
    max-width: 72ch;
    margin-bottom: var(--space-3xl);
  }

  .page-title {
    font-size: var(--text-4xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-lg);
  }

  .page-lead {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: var(--leading-loose);
  }

  .page-lead a {
    color: var(--color-primary);
    text-decoration: none;
  }

  .page-lead a:hover {
    text-decoration: underline;
  }

  .faq-section {
    margin-bottom: var(--space-3xl);
  }

  .faq-section__heading {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 2px solid var(--color-primary);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .faq-item {
    background-color: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .faq-item[open] {
    border-color: var(--color-primary-light);
  }

  .faq-item__question {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    padding: var(--space-lg) var(--space-xl);
    cursor: pointer;
    list-style: none;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    line-height: var(--leading-normal);
    transition: background-color var(--transition-fast);
    min-height: 44px;
  }

  .faq-item__question::-webkit-details-marker {
    display: none;
  }

  .faq-item__question:hover {
    background-color: var(--color-surface);
  }

  .faq-item__q-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    background-color: var(--color-primary);
    color: var(--color-paper);
    font-size: var(--text-xs);
    font-weight: 700;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }

  .faq-item__q-text {
    flex: 1;
  }

  .faq-item__chevron {
    flex-shrink: 0;
    color: var(--color-text-secondary);
    transition: transform var(--transition-fast);
    font-size: var(--text-lg);
  }

  .faq-item[open] .faq-item__chevron {
    transform: rotate(180deg);
  }

  .faq-item__answer {
    display: flex;
    gap: var(--space-md);
    padding: 0 var(--space-xl) var(--space-xl);
    padding-left: calc(var(--space-xl) + 24px + var(--space-md));
  }

  .faq-item__a-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    background-color: var(--color-surface);
    color: var(--color-primary);
    font-size: var(--text-xs);
    font-weight: 700;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
    border: 1px solid var(--color-border);
  }

  .faq-item__answer p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  .empty-state {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    text-align: center;
    padding: var(--space-3xl);
  }

  .contact-cta {
    padding: var(--space-3xl);
    background-color: var(--color-primary-pale);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .contact-cta__title {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .contact-cta__desc {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    min-height: 44px;
    transition: background-color var(--transition-fast);
  }

  .btn--primary {
    background-color: var(--color-primary);
    color: var(--color-paper);
    border: 2px solid var(--color-primary);
  }

  .btn--primary:hover {
    background-color: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
  }
</style>

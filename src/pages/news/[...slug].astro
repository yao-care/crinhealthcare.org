---
import Article from '@layouts/Article.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { getCollection, render } from 'astro:content';
import { url } from '@utils/url';

export async function getStaticPaths() {
  const entries = await getCollection('news');
  return entries
    .filter((e) => !e.data.draft)
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, source, sourceUrl, publishDate, summary, tags, editorComment, internationalBenchmark } = entry.data;

function breadcrumb(items: Array<{ name: string; url: string }>) {
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.name,
      item: item.url,
    })),
  };
}

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsArticle',
  headline: title,
  description: summary,
  datePublished: publishDate.toISOString(),
  url: `https://crinhealthcare.org/news/${entry.id}/`,
  publisher: {
    '@type': 'Organization',
    name: '國際醫療減碳協會',
    url: 'https://crinhealthcare.org',
  },
};

const breadcrumbSchema = breadcrumb([
  { name: '首頁', url: 'https://crinhealthcare.org/' },
  { name: '新聞', url: 'https://crinhealthcare.org/news/' },
  { name: title, url: `https://crinhealthcare.org/news/${entry.id}/` },
]);
---

<Article
  title={title}
  description={summary}
  publishDate={publishDate}
  tags={tags}
  ogImage={url(`/og/news/${entry.id}.png`)}
>
  <JsonLd schema={[articleSchema, breadcrumbSchema]} />
  <div class="news-meta">
    <div class="news-source">
      <span class="news-source__label">來源：</span>
      {sourceUrl ? (
        <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="news-source__link">
          {source}
          <span class="news-source__ext" aria-label="在新分頁開啟">↗</span>
        </a>
      ) : (
        <span class="news-source__name">{source}</span>
      )}
    </div>
  </div>

  <div class="news-summary">
    <p>{summary}</p>
  </div>

  {editorComment && (
    <div class="editor-comment" role="note" aria-label="編輯評論">
      <div class="editor-comment__icon" aria-hidden="true">✦</div>
      <div class="editor-comment__content">
        <div class="editor-comment__label">編輯評論</div>
        <p class="editor-comment__text">{editorComment}</p>
      </div>
    </div>
  )}

  <Content />

  {internationalBenchmark && (
    <aside class="benchmark" aria-label="國際標竿">
      <h3 class="benchmark__title">國際標竿：{internationalBenchmark.region}</h3>
      <div class="benchmark__body">
        <h4 class="benchmark__subtitle">{internationalBenchmark.title}</h4>
        <p class="benchmark__summary">{internationalBenchmark.summary}</p>
        <p class="benchmark__comparison">{internationalBenchmark.comparison}</p>
        <a
          href={internationalBenchmark.sourceUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="benchmark__link"
        >
          閱讀原始資料 ↗
        </a>
      </div>
    </aside>
  )}
</Article>

<style>
  .news-meta {
    margin-bottom: var(--space-lg);
  }

  .news-source {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .news-source__label {
    font-weight: 600;
  }

  .news-source__link {
    color: var(--color-primary);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .news-source__link:hover {
    text-decoration: underline;
  }

  .news-source__ext {
    font-size: var(--text-xs);
  }

  .news-source__name {
    color: var(--color-text);
  }

  .news-summary {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-loose);
    border-left: 4px solid var(--color-primary);
    padding-left: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .editor-comment {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background-color: var(--color-notice-bg);
    border: 1px solid var(--color-notice-border);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-2xl);
  }

  .editor-comment__icon {
    font-size: var(--text-xl);
    color: var(--color-notice-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .editor-comment__label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-notice-accent);
    margin-bottom: var(--space-sm);
  }

  .editor-comment__text {
    font-size: var(--text-sm);
    color: var(--color-notice-text);
    line-height: var(--leading-normal);
  }

  .benchmark {
    margin-top: var(--space-3xl);
    padding: var(--space-xl);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    border-top: 4px solid var(--color-chart-4);
  }

  .benchmark__title {
    font-size: var(--text-lg);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .benchmark__subtitle {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .benchmark__summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-sm);
  }

  .benchmark__comparison {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-lg);
    font-style: italic;
  }

  .benchmark__link {
    font-size: var(--text-sm);
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }

  .benchmark__link:hover {
    text-decoration: underline;
  }
</style>

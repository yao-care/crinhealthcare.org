---
import Page from '@layouts/Page.astro';
import JsonLd from '@components/seo/JsonLd.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { name, description, icon, features } = entry.data;

function breadcrumb(items: Array<{ name: string; url: string }>) {
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.name,
      item: item.url,
    })),
  };
}

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: name,
  description: description,
  url: `https://crinhealthcare.org/services/${entry.id}/`,
  provider: {
    '@type': 'Organization',
    name: '國際醫療減碳協會',
    url: 'https://crinhealthcare.org',
  },
};

const breadcrumbSchema = breadcrumb([
  { name: '首頁', url: 'https://crinhealthcare.org/' },
  { name: '服務項目', url: 'https://crinhealthcare.org/services/' },
  { name: name, url: `https://crinhealthcare.org/services/${entry.id}/` },
]);
---

<Page
  title={name}
  description={description}
  ogImage={`/og/services/${entry.id}.png`}
>
  <JsonLd schema={[serviceSchema, breadcrumbSchema]} />
  <div class="container page-content">

    <header class="service-header">
      <div class="service-header__icon" aria-hidden="true">
        <svg width="40" height="40">
          <use href={`/icons.svg#${icon}`} />
        </svg>
      </div>
      <h1 class="service-header__title">{name}</h1>
      <p class="service-header__desc">{description}</p>
    </header>

    {features && features.length > 0 && (
      <section class="features-section">
        <h2 class="section-heading">服務特色</h2>
        <div class="features-grid">
          {features.map((feature) => (
            <div class="feature-card">
              <h3 class="feature-card__title">{feature.title}</h3>
              <p class="feature-card__desc">{feature.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="content-section">
      <div class="prose">
        <Content />
      </div>
    </section>

    <div class="cta-block">
      <h2 class="cta-block__title">有興趣了解更多？</h2>
      <p class="cta-block__desc">歡迎聯絡協會，我們將為您說明如何啟動此項服務。</p>
      <div class="cta-block__actions">
        <a href="/contact/" class="btn btn--primary">立即聯繫</a>
        <a href="/services/" class="btn btn--outline">瀏覽所有服務</a>
      </div>
    </div>

  </div>
</Page>

<style>
  .page-content {
    padding-block: var(--space-3xl);
  }

  .service-header {
    max-width: 72ch;
    margin-bottom: var(--space-3xl);
  }

  .service-header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    background-color: var(--color-primary-pale);
    border-radius: var(--radius-md);
    color: var(--color-primary);
    margin-bottom: var(--space-lg);
  }

  .service-header__title {
    font-size: var(--text-4xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-md);
  }

  .service-header__desc {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: var(--leading-loose);
  }

  .features-section {
    margin-bottom: var(--space-3xl);
  }

  .section-heading {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .feature-card {
    padding: var(--space-xl);
    background-color: var(--color-surface);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-primary);
  }

  .feature-card__title {
    font-size: var(--text-lg);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .feature-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  .content-section {
    margin-bottom: var(--space-3xl);
  }

  .cta-block {
    padding: var(--space-3xl);
    background-color: var(--color-primary-pale);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .cta-block__title {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .cta-block__desc {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
  }

  .cta-block__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-md) var(--space-xl);
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    min-height: 44px;
    transition: background-color var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);
  }

  .btn--primary {
    background-color: var(--color-primary);
    color: var(--color-paper);
    border: 2px solid var(--color-primary);
  }

  .btn--primary:hover {
    background-color: var(--color-primary-dark);
    border-color: var(--color-primary-dark);
  }

  .btn--outline {
    background-color: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .btn--outline:hover {
    background-color: var(--color-primary);
    color: var(--color-paper);
  }

  @media (max-width: 768px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';
import { url } from '@utils/url';

const allInsights = await getCollection('insights', ({ data }) => !data.draft);
const sorted = allInsights.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const categories = [
  { id: 'policy', label: '政策解讀' },
  { id: 'guide', label: '知識指南' },
  { id: 'benchmark', label: '國際標竿' },
] as const;

const byCategory = {
  policy: sorted.filter((e) => e.data.category === 'policy'),
  guide: sorted.filter((e) => e.data.category === 'guide'),
  benchmark: sorted.filter((e) => e.data.category === 'benchmark'),
};
---

<Page
  title="知識庫"
  description="國際醫療減碳協會的知識庫，涵蓋政策解讀、操作指南與國際標竿案例，協助醫療機構掌握最新淨零趨勢。"
>
  <div class="container page-content">

    <header class="page-header">
      <h1 class="page-title">知識庫</h1>
      <p class="page-lead">
        深度解析政策法規、分享操作指南，並引介國際標竿案例，協助醫療機構掌握減碳知識。
      </p>
    </header>

    <div class="tabs-container">
      {categories.map((cat, i) => (
        <>
          <input
            type="radio"
            name="insights-tab"
            id={`tab-${cat.id}`}
            class="tab-radio"
            checked={i === 0}
          />
          <label for={`tab-${cat.id}`} class="tab-label">{cat.label}</label>
        </>
      ))}

      {categories.map((cat) => (
        <div class={`tab-panel tab-panel--${cat.id}`}>
          {byCategory[cat.id].length === 0 ? (
            <p class="empty-state">此分類尚無文章，敬請期待。</p>
          ) : (
            <div class="insights-grid">
              {byCategory[cat.id].map((entry) => (
                <a href={url(`/insights/${entry.id}/`)} class="insight-card">
                  <div class="insight-card__meta">
                    <time class="insight-card__date" datetime={entry.data.publishDate.toISOString()}>
                      {entry.data.publishDate.toLocaleDateString('zh-Hant-TW', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    {entry.data.internationalBenchmark && (
                      <span class="insight-card__badge">國際</span>
                    )}
                  </div>
                  <h3 class="insight-card__title">{entry.data.title}</h3>
                  <p class="insight-card__summary">{entry.data.summary}</p>
                  {entry.data.tags.length > 0 && (
                    <div class="insight-card__tags">
                      {entry.data.tags.map((tag) => (
                        <span class="insight-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

  </div>
</Page>

<style>
  .page-content {
    padding-block: var(--space-3xl);
  }

  .page-header {
    max-width: 72ch;
    margin-bottom: var(--space-3xl);
  }

  .page-title {
    font-size: var(--text-4xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-lg);
  }

  .page-lead {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: var(--leading-loose);
  }

  /* CSS-only tabs using radio buttons */
  .tabs-container {
    display: grid;
    grid-template-columns: repeat(3, auto) 1fr;
    grid-template-rows: auto auto;
    align-items: start;
  }

  .tab-radio {
    display: none;
  }

  .tab-label {
    grid-row: 1;
    padding: var(--space-md) var(--space-xl);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-bottom: none;
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    cursor: pointer;
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    transition: background-color var(--transition-fast), color var(--transition-fast);
    white-space: nowrap;
  }

  .tab-label:hover {
    color: var(--color-primary);
    background-color: var(--color-primary-pale);
  }

  .tab-panel {
    grid-row: 2;
    grid-column: 1 / -1;
    display: none;
    padding: var(--space-2xl);
    background-color: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: 0 var(--radius-md) var(--radius-md) var(--radius-md);
  }

  /* Show/hide panels based on radio state */
  #tab-policy:checked ~ .tab-panel--policy,
  #tab-guide:checked ~ .tab-panel--guide,
  #tab-benchmark:checked ~ .tab-panel--benchmark {
    display: block;
  }

  /* Active tab label */
  #tab-policy:checked ~ label[for="tab-policy"],
  #tab-guide:checked ~ label[for="tab-guide"],
  #tab-benchmark:checked ~ label[for="tab-benchmark"] {
    background-color: var(--color-paper);
    color: var(--color-primary);
    border-color: var(--color-border);
    position: relative;
    z-index: 1;
  }

  .empty-state {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    padding: var(--space-2xl);
    text-align: center;
  }

  .insights-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .insight-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-xl);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition-normal), border-color var(--transition-normal);
  }

  .insight-card:hover {
    box-shadow: var(--shadow-sm);
    border-color: var(--color-primary-light);
  }

  .insight-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .insight-card__date {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .insight-card__badge {
    padding: 2px var(--space-sm);
    background-color: var(--color-chart-4);
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    border-radius: var(--radius-sm);
  }

  .insight-card__title {
    font-size: var(--text-lg);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
  }

  .insight-card__summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .insight-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .insight-tag {
    padding: 2px var(--space-sm);
    background-color: var(--color-paper);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  @media (max-width: 640px) {
    .tabs-container {
      grid-template-columns: 1fr;
    }

    .tab-label {
      border-bottom: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
    }

    .tab-panel {
      border-radius: var(--radius-md);
    }

    .insights-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

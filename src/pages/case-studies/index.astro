---
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';
import { url } from '@utils/url';

const cases = await getCollection('case-studies', ({ data }) => !data.draft);
const sorted = cases.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const systemLabel: Record<string, string> = {
  military: '國軍醫院',
  veterans: '榮民醫院',
  other: '其他醫院',
};

const systemColor: Record<string, string> = {
  military: 'badge--military',
  veterans: 'badge--veterans',
  other: 'badge--other',
};

const serviceLabel: Record<string, string> = {
  'carbon-audit': '碳盤查',
  'ems': '能管系統',
  'esg-report': 'ESG 報告',
  'awards': '獎項輔導',
  'subsidies': '補助申請',
  'health-taiwan': '健康台灣',
};
---

<Page
  title="合作案例"
  description="國際醫療減碳協會合作醫院案例，包含碳盤查認證、節能成效與ESG報告等成果紀錄。"
>
  <div class="container page-content">

    <header class="page-header">
      <h1 class="page-title">合作案例</h1>
      <p class="page-lead">
        每一家醫院都有獨特的減碳旅程。以下是協會協助的真實案例記錄。
      </p>
    </header>

    {sorted.length === 0 ? (
      <p class="empty-state">案例資料準備中，敬請期待。</p>
    ) : (
      <div class="case-grid">
        {sorted.map((c) => (
          <a href={url(`/case-studies/${c.id}/`)} class="case-card">
            <div class="case-card__header">
              <span class={`case-card__badge ${systemColor[c.data.hospital.system]}`}>
                {systemLabel[c.data.hospital.system]}
              </span>
              <span class="case-card__location">{c.data.hospital.location}</span>
            </div>
            <h2 class="case-card__name">{c.data.hospital.name}</h2>
            <p class="case-card__summary">{c.data.summary}</p>
            <div class="case-card__services">
              {c.data.services.map((svc) => (
                <span class="case-card__service">{serviceLabel[svc] ?? svc}</span>
              ))}
            </div>
            {c.data.metrics.certifications.length > 0 && (
              <div class="case-card__certs">
                {c.data.metrics.certifications.map((cert) => (
                  <span class="case-card__cert">{cert}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    )}

  </div>
</Page>

<style>
  .page-content {
    padding-block: var(--space-3xl);
  }

  .page-header {
    max-width: 72ch;
    margin-bottom: var(--space-3xl);
  }

  .page-title {
    font-size: var(--text-4xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-lg);
  }

  .page-lead {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: var(--leading-loose);
  }

  .empty-state {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    text-align: center;
    padding: var(--space-3xl);
  }

  .case-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .case-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding: var(--space-xl);
    background-color: var(--color-paper);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition-normal), border-color var(--transition-normal);
  }

  .case-card:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary-light);
  }

  .case-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .case-card__badge {
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-sm);
  }

  .badge--military {
    background-color: #e8f0fe;
    color: #1a56db;
  }

  .badge--veterans {
    background-color: #fef3c7;
    color: #92400e;
  }

  .badge--other {
    background-color: var(--color-primary-pale);
    color: var(--color-primary);
  }

  .case-card__location {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .case-card__name {
    font-size: var(--text-xl);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-text);
    line-height: var(--leading-tight);
  }

  .case-card__summary {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .case-card__services {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .case-card__service {
    padding: var(--space-xs) var(--space-sm);
    background-color: var(--color-surface);
    color: var(--color-text-secondary);
    font-size: var(--text-xs);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }

  .case-card__certs {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .case-card__cert {
    font-size: var(--text-xs);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .case-card__cert::before {
    content: '✓';
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .case-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

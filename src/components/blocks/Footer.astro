---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: '關於協會', href: '/about/' },
  { label: '服務項目', href: '/services/' },
  { label: '合作成果', href: '/case-studies/' },
  { label: '新聞', href: '/news/' },
];

const resourceLinks = [
  { label: '深度內容', href: '/insights/' },
  { label: '詞彙庫', href: '/glossary/' },
  { label: 'FAQ', href: '/faq/' },
  { label: '加入會員', href: '/join/' },
];
---

<footer class="footer">
  <div class="container footer__grid">
    <!-- Col 1: About -->
    <div class="footer__col footer__col--about">
      <a href="/" class="footer__logo" aria-label="國際醫療減碳協會 首頁">
        <svg width="32" height="32" viewBox="0 0 36 36" aria-hidden="true" focusable="false">
          <circle cx="18" cy="18" r="16" fill="var(--color-primary)" />
          <rect x="14" y="9" width="8" height="18" rx="2" fill="var(--color-paper)" />
          <rect x="9" y="14" width="18" height="8" rx="2" fill="var(--color-paper)" />
          <ellipse cx="26" cy="11" rx="5" ry="3" fill="var(--color-accent)" transform="rotate(-30 26 11)" />
        </svg>
        <span>國際醫療減碳協會</span>
      </a>
      <p class="footer__tagline">
        協助醫療院所達成碳盤查、能源管理、ESG報告與淨零排放目標。
      </p>
    </div>

    <!-- Col 2: Quick links -->
    <div class="footer__col">
      <h3 class="footer__heading">快速連結</h3>
      <ul class="footer__list">
        {quickLinks.map((link) => (
          <li><a href={link.href} class="footer__link">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Col 3: Resources -->
    <div class="footer__col">
      <h3 class="footer__heading">資源</h3>
      <ul class="footer__list">
        {resourceLinks.map((link) => (
          <li><a href={link.href} class="footer__link">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Col 4: Contact -->
    <div class="footer__col">
      <h3 class="footer__heading">聯絡我們</h3>
      <address class="footer__contact">
        <p>
          <span class="footer__contact-label">電子郵件</span>
          <a href="mailto:contact@crinhealthcare.org" class="footer__link">
            contact@crinhealthcare.org
          </a>
        </p>
        <p>
          <span class="footer__contact-label">地址</span>
          <span>台灣</span>
        </p>
      </address>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">
        &copy; {currentYear} 國際醫療減碳協會。保留一切權利。
      </p>
      <!-- 隱私政策、使用條款頁面待建立後啟用 -->
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-2xl);
    padding-block: var(--space-2xl);
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--color-text);
    font-weight: 700;
    font-size: var(--text-sm);
    font-family: var(--font-heading);
    margin-bottom: var(--space-md);
    min-height: 44px;
  }

  .footer__logo:hover {
    color: var(--color-primary);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
  }

  .footer__heading {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__link {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
    display: inline-flex;
    min-height: 28px;
    align-items: center;
  }

  .footer__link:hover {
    color: var(--color-primary);
  }

  .footer__contact {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .footer__contact p {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer__contact-label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }

  /* Bottom bar */
  .footer__bottom {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-md);
  }

  .footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer__copy {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .footer__legal {
    display: flex;
    gap: var(--space-md);
  }

  .footer__legal-link {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    text-decoration: none;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: color var(--transition-fast);
  }

  .footer__legal-link:hover {
    color: var(--color-primary);
  }

  /* ─── Responsive ───────────────────────────────────────────────────────── */

  /* 4 cols → 2 cols */
  @media (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
    }

    .footer__col--about {
      grid-column: span 2;
    }
  }

  /* 2 cols → 1 col */
  @media (max-width: 600px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }

    .footer__col--about {
      grid-column: span 1;
    }

    .footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

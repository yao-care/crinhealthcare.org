---
import { url } from '@utils/url';

const navItems = [
  { label: '關於協會', href: url('/about/') },
  { label: '服務項目', href: url('/services/') },
  { label: '合作成果', href: url('/case-studies/') },
  { label: '新聞', href: url('/news/') },
  { label: '深度內容', href: url('/insights/') },
  { label: '詞彙庫', href: url('/glossary/') },
  { label: 'FAQ', href: url('/faq/') },
];

const currentPath = Astro.url.pathname;
---

<header class="nav">
  <div class="container nav__inner">
    <!-- Logo -->
    <a href={url('/')} class="nav__logo" aria-label="國際醫療減碳協會 首頁">
      <svg width="36" height="36" viewBox="0 0 36 36" aria-hidden="true" focusable="false">
        <circle cx="18" cy="18" r="16" fill="var(--color-primary)" />
        <rect x="14" y="9" width="8" height="18" rx="2" fill="var(--color-paper)" />
        <rect x="9" y="14" width="18" height="8" rx="2" fill="var(--color-paper)" />
        <ellipse cx="26" cy="11" rx="5" ry="3" fill="var(--color-accent)" transform="rotate(-30 26 11)" />
      </svg>
      <span class="nav__logo-text">國際醫療減碳協會</span>
    </a>

    <!-- Pure CSS hamburger: checkbox + label are siblings to nav__menu inside nav__inner -->
    <input type="checkbox" id="nav-toggle" class="nav__toggle-input" />
    <label for="nav-toggle" class="nav__toggle" aria-label="開啟選單">
      <span class="nav__burger"></span>
      <span class="nav__burger"></span>
      <span class="nav__burger"></span>
    </label>

    <nav class="nav__menu" aria-label="主要導覽">
      <ul class="nav__list">
        {
          navItems.map((item) => (
            <li class="nav__item">
              <a
                href={item.href}
                class={`nav__link${currentPath.startsWith(item.href) ? ' nav__link--active' : ''}`}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <a href={url('/join/')} class="nav__cta">加入會員</a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-paper);
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding-block: var(--space-sm);
    min-height: 64px;
    flex-wrap: wrap;
    position: relative;
  }

  /* Logo */
  .nav__logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--color-text);
    font-weight: 700;
    font-size: var(--text-sm);
    font-family: var(--font-heading);
    flex-shrink: 0;
    min-height: 44px;
  }

  .nav__logo:hover {
    color: var(--color-primary);
  }

  .nav__logo-text {
    line-height: 1.2;
  }

  /* Hamburger checkbox — visually hidden but accessible */
  .nav__toggle-input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  /* Hamburger label — hidden on desktop */
  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: background-color var(--transition-fast);
    order: 3;
  }

  .nav__toggle:hover {
    background-color: var(--color-surface);
  }

  .nav__burger {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 2px;
    transition:
      transform var(--transition-fast),
      opacity var(--transition-fast);
    pointer-events: none;
  }

  /* Menu — flex row on desktop */
  .nav__menu {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    display: flex;
    align-items: center;
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    min-height: 44px;
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .nav__link:hover,
  .nav__link--active {
    color: var(--color-primary);
    background-color: var(--color-primary-pale);
  }

  .nav__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xs) var(--space-md);
    background-color: var(--color-primary);
    color: var(--color-paper);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-sm);
    text-decoration: none;
    min-height: 44px;
    min-width: 44px;
    border: 2px solid var(--color-primary);
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast);
    white-space: nowrap;
  }

  .nav__cta:hover {
    background-color: var(--color-primary-light);
    border-color: var(--color-primary-light);
    color: var(--color-paper);
  }

  /* ─── Mobile (≤1024px) ─────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .nav__toggle {
      display: flex;
    }

    /* Menu: hidden by default on mobile */
    .nav__menu {
      display: none;
      order: 4;
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding-block: var(--space-sm);
      border-top: 1px solid var(--color-border);
    }

    /* Show menu when checkbox is checked — checkbox and menu are siblings inside nav__inner */
    .nav__toggle-input:checked ~ .nav__menu {
      display: flex;
    }

    /* Burger → X animation when checked */
    .nav__toggle-input:checked ~ .nav__toggle .nav__burger:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav__toggle-input:checked ~ .nav__toggle .nav__burger:nth-child(2) {
      opacity: 0;
    }

    .nav__toggle-input:checked ~ .nav__toggle .nav__burger:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      width: 100%;
    }

    .nav__link {
      padding: var(--space-sm) var(--space-md);
      width: 100%;
      font-size: var(--text-base);
      border-radius: var(--radius-sm);
    }

    .nav__cta {
      margin-top: var(--space-sm);
      width: 100%;
      justify-content: center;
      padding: var(--space-sm) var(--space-md);
    }
  }
</style>

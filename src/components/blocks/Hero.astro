---
---

<section class="hero">
  <div class="container hero__inner">
    <!-- Left: text content -->
    <div class="hero__content">
      <h1 class="hero__title">
        協助醫療院所<br />達成淨零排放
      </h1>
      <p class="hero__subtitle">
        國際醫療減碳協會整合碳盤查、能源管理系統、ESG報告及政府補助申請，
        為台灣醫療院所提供一站式永續解決方案。
      </p>
      <div class="hero__actions">
        <a href="/services/" class="hero__btn hero__btn--primary">了解服務</a>
        <a href="/join/" class="hero__btn hero__btn--secondary">加入會員</a>
      </div>
    </div>

    <!-- Right: SVG illustration -->
    <div class="hero__visual" aria-hidden="true">
      <svg
        viewBox="0 0 400 340"
        xmlns="http://www.w3.org/2000/svg"
        class="hero__svg"
        role="img"
        aria-label="醫療院所永續發展插圖"
      >
        <!-- Sky background -->
        <rect width="400" height="340" fill="var(--color-primary-pale)" rx="16" />

        <!-- Ground -->
        <ellipse cx="200" cy="310" rx="180" ry="30" fill="var(--color-accent-light)" opacity="0.5" />

        <!-- Hospital building -->
        <rect x="120" y="140" width="160" height="140" fill="var(--color-paper)" rx="4" />
        <rect x="120" y="130" width="160" height="20" fill="var(--color-primary)" rx="4" />

        <!-- Hospital windows -->
        <rect x="140" y="165" width="30" height="25" fill="var(--color-primary-pale)" rx="2" />
        <rect x="185" y="165" width="30" height="25" fill="var(--color-primary-pale)" rx="2" />
        <rect x="230" y="165" width="30" height="25" fill="var(--color-primary-pale)" rx="2" />
        <rect x="140" y="205" width="30" height="25" fill="var(--color-primary-pale)" rx="2" />
        <rect x="230" y="205" width="30" height="25" fill="var(--color-primary-pale)" rx="2" />

        <!-- Hospital door -->
        <rect x="183" y="240" width="34" height="40" fill="var(--color-primary-pale)" rx="3" />

        <!-- Medical cross on building -->
        <rect x="194" y="90" width="12" height="32" fill="var(--color-paper)" rx="2" />
        <rect x="184" y="100" width="32" height="12" fill="var(--color-paper)" rx="2" />

        <!-- Chimney / solar panels on roof -->
        <rect x="130" y="120" width="40" height="12" fill="var(--color-primary-light)" rx="2" opacity="0.8" />
        <rect x="130" y="120" width="12" height="12" fill="var(--color-accent)" rx="1" opacity="0.9" />
        <rect x="146" y="120" width="12" height="12" fill="var(--color-accent)" rx="1" opacity="0.9" />
        <rect x="162" y="120" width="12" height="12" fill="var(--color-accent)" rx="1" opacity="0.9" />

        <!-- Large tree left -->
        <rect x="68" y="230" width="10" height="50" fill="var(--color-accent)" rx="3" />
        <ellipse cx="73" cy="210" rx="28" ry="32" fill="var(--color-accent)" opacity="0.85" />
        <ellipse cx="73" cy="200" rx="20" ry="22" fill="var(--color-accent-light)" opacity="0.6" />

        <!-- Small tree right -->
        <rect x="316" y="248" width="8" height="32" fill="var(--color-accent)" rx="3" />
        <ellipse cx="320" cy="232" rx="20" ry="24" fill="var(--color-accent)" opacity="0.85" />

        <!-- Sun / glow top right -->
        <circle cx="340" cy="60" r="34" fill="var(--color-energy)" opacity="0.18" />
        <circle cx="340" cy="60" r="22" fill="var(--color-energy)" opacity="0.30" />
        <circle cx="340" cy="60" r="14" fill="var(--color-energy)" opacity="0.60" />

        <!-- CO2 down arrow (reduction symbol) -->
        <text x="310" y="110" font-size="11" fill="var(--color-primary)" font-family="sans-serif" font-weight="700" text-anchor="middle">CO₂↓</text>

        <!-- Leaf badge -->
        <circle cx="58" cy="158" r="22" fill="var(--color-accent)" opacity="0.15" />
        <ellipse cx="58" cy="158" rx="12" ry="16" fill="var(--color-accent)" transform="rotate(-20 58 158)" />
        <ellipse cx="58" cy="158" rx="6" ry="10" fill="var(--color-accent-light)" transform="rotate(-20 58 158)" />

        <!-- Clouds -->
        <ellipse cx="90" cy="52" rx="30" ry="14" fill="var(--color-paper)" opacity="0.8" />
        <ellipse cx="110" cy="46" rx="22" ry="14" fill="var(--color-paper)" opacity="0.8" />
        <ellipse cx="70" cy="48" rx="18" ry="12" fill="var(--color-paper)" opacity="0.8" />
        <ellipse cx="260" cy="70" rx="24" ry="11" fill="var(--color-paper)" opacity="0.6" />
        <ellipse cx="278" cy="64" rx="18" ry="11" fill="var(--color-paper)" opacity="0.6" />
      </svg>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary-pale) 0%, var(--color-paper) 100%);
    padding-block: var(--space-3xl);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .hero__title {
    font-size: var(--text-hero);
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    max-width: 48ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
  }

  /* CTA buttons */
  .hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-sm) var(--space-xl);
    font-size: var(--text-base);
    font-weight: 600;
    border-radius: var(--radius-sm);
    text-decoration: none;
    min-height: 44px;
    min-width: 44px;
    border: 2px solid transparent;
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast),
      border-color var(--transition-fast);
    white-space: nowrap;
  }

  .hero__btn--primary {
    background-color: var(--color-primary);
    color: var(--color-paper);
    border-color: var(--color-primary);
  }

  .hero__btn--primary:hover {
    background-color: var(--color-primary-light);
    border-color: var(--color-primary-light);
    color: var(--color-paper);
  }

  .hero__btn--secondary {
    background-color: transparent;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .hero__btn--secondary:hover {
    background-color: var(--color-primary-pale);
  }

  /* SVG illustration */
  .hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__svg {
    width: 100%;
    max-width: 460px;
    height: auto;
    display: block;
  }

  /* ─── Responsive ───────────────────────────────────────────────────────── */

  /* Stack vertically on mobile, visual first */
  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .hero__visual {
      order: -1;
    }

    .hero__svg {
      max-width: 320px;
    }

    .hero__title {
      font-size: var(--text-3xl);
    }
  }
</style>

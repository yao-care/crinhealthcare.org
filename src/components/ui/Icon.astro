---
interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  class={className}
  aria-hidden="true"
  focusable="false"
>
  <use href={`/icons.svg#${name}`} />
</svg>

<style>
  svg {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }
</style>

---
import '@/styles/global.css';
import { url } from '@utils/url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = '國際醫療減碳協會協助醫療院所達成碳盤查、能源管理、ESG報告與淨零排放目標。',
  ogImage = '/og-default.png',
} = Astro.props;

const siteTitle = `${title} | 國際醫療減碳協會`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="sitemap" href={url('/sitemap-index.xml')} />
    <link rel="alternate" type="application/rss+xml" title="國際醫療減碳協會 新聞" href={url('/rss.xml')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content="國際醫療減碳協會" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Google Fonts: Noto Sans TC -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="skip-link">跳至主要內容</a>
    <slot />
  </body>
</html>

---
import '@/styles/global.css';
// Self-host Noto Sans TC（取代 Google Fonts）：消除外部子資源、SRI 90003 與隱私顧慮
// 根目錄 weight CSS 帶 unicode-range 涵蓋拉丁/數字；chinese-traditional 為繁中整包分片
import '@fontsource/noto-sans-tc/400.css';
import '@fontsource/noto-sans-tc/500.css';
import '@fontsource/noto-sans-tc/600.css';
import '@fontsource/noto-sans-tc/700.css';
import '@fontsource/noto-sans-tc/chinese-traditional-400.css';
import '@fontsource/noto-sans-tc/chinese-traditional-500.css';
import '@fontsource/noto-sans-tc/chinese-traditional-600.css';
import '@fontsource/noto-sans-tc/chinese-traditional-700.css';
import { url } from '@utils/url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = '國際醫療減碳協會協助醫療院所達成碳盤查、能源管理、ESG報告與淨零排放目標。',
  ogImage = '/og/index.png',
} = Astro.props;

const siteTitle = `${title} | 國際醫療減碳協會`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <!--
      Content-Security-Policy（修復 ZAP 10038）：GitHub Pages 純靜態無法設 HTTP 標頭，改用 meta。
      站內含 inline <script>（JSON-LD / Astro island）與 inline <style>，故 script/style-src 需 'unsafe-inline'；
      字體已 self-host（font-src 'self' data:，小分片被 Vite inline 為 data: URI）；form-action 允許表單 POST 至 Formspree。
      註：frame-ancestors 在 <meta> 中不生效（僅 HTTP 標頭），故防點擊劫持 10020 無法在此修復。
    -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; form-action 'self' https://formspree.io; upgrade-insecure-requests"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />
    <link rel="sitemap" href={url('/sitemap-index.xml')} />
    <link rel="alternate" type="application/rss+xml" title="國際醫療減碳協會 新聞" href={url('/rss.xml')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content="國際醫療減碳協會" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
  </head>
  <body>
    <a href="#main" class="skip-link">跳至主要內容</a>
    <slot />
  </body>
</html>
